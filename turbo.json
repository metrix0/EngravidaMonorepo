{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "GROQ_API_KEY",
    "GROQ_API_KEY_2",
    "GROQ_API_KEY_3",
    "GROQ_API_KEY_4",
    "GROQ_API_KEY_5",
    "GROQ_API_KEY_6",
    "GROQ_API_KEY_7",
    "GROQ_API_KEY_8",
    "GROQ_MODEL_ANALYSIS",
    "GROQ_MODEL_ANALYSIS_2",
    "GROQ_MODEL_ANALYSIS_3",
    "GROQ_MODEL_ANALYSIS_4",
    "OPENAI_API_KEY",
    "OPENAI_MODEL_ANALYSIS",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SPREADSHEET_ID",
    "SHEET_NAME",
    "GOOGLE_CLIENT_EMAIL",
    "GOOGLE_PRIVATE_KEY"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {}
  }
}