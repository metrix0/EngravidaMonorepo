{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["react", "react-dom"],
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "isolatedModules": true
  },
  "include": ["**/*.ts", "**/*.tsx"]
}